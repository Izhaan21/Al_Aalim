<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main golden bead -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:endColor="#D4AF37"
                android:startColor="#FFD700"
                android:type="linear" />
            <size
                android:width="18dp"
                android:height="18dp" />
            <stroke
                android:width="1dp"
                android:color="#B8860B" />
        </shape>
    </item>
    
    <!-- Teal accent on left side (app theme dark teal) -->
    <item
        android:left="0dp"
        android:right="11dp">
        <shape android:shape="oval">
            <solid android:color="#0F4C5C" />
            <size
                android:width="7dp"
                android:height="18dp" />
        </shape>
    </item>
</layer-list>
