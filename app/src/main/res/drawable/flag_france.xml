<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Blue stripe -->
    <item android:right="16dp">
        <shape android:shape="rectangle">
            <solid android:color="#002654" />
            <corners android:topLeftRadius="4dp" android:bottomLeftRadius="4dp" />
        </shape>
    </item>
    <!-- White stripe -->
    <item android:left="8dp" android:right="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <!-- Red stripe -->
    <item android:left="16dp">
        <shape android:shape="rectangle">
            <solid android:color="#ED2939" />
            <corners android:topRightRadius="4dp" android:bottomRightRadius="4dp" />
        </shape>
    </item>
</layer-list>
