<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="120dp"
    android:height="120dp"
    android:viewportWidth="120"
    android:viewportHeight="120">
    <!-- Elegant Arabesque Corner - Top Left style -->
    <group>
        <!-- Main curved arabesque -->
        <path
            android:pathData="M10,60 Q10,10 60,10"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="1.5"
            android:strokeAlpha="0.6"
            android:fillColor="@android:color/transparent"/>
        <!-- Inner curve -->
        <path
            android:pathData="M20,50 Q20,20 50,20"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="1"
            android:strokeAlpha="0.4"
            android:fillColor="@android:color/transparent"/>
        <!-- Decorative dots -->
        <path
            android:pathData="M15,15 m-2,0 a2,2 0,1 1,4 0 a2,2 0,1 1,-4 0"
            android:fillColor="#FFD700"
            android:fillAlpha="0.8"/>
        <!-- Ornamental flourish -->
        <path
            android:pathData="M5,40 Q15,35 10,25 Q20,30 25,20"
            android:strokeColor="#FFD700"
            android:strokeWidth="1"
            android:strokeAlpha="0.5"
            android:fillColor="@android:color/transparent"/>
    </group>
</vector>
