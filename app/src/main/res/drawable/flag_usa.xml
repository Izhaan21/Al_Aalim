<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Red stripe -->
    <item android:bottom="16dp">
        <shape android:shape="rectangle">
            <solid android:color="#B22234" />
            <corners android:topLeftRadius="4dp" android:topRightRadius="4dp" />
        </shape>
    </item>
    <!-- White stripe -->
    <item android:top="8dp" android:bottom="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <!-- Blue stripe -->
    <item android:top="16dp">
        <shape android:shape="rectangle">
            <solid android:color="#3C3B6E" />
            <corners android:bottomLeftRadius="4dp" android:bottomRightRadius="4dp" />
        </shape>
    </item>
</layer-list>
