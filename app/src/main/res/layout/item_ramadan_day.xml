<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="2dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/card_day"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintDimensionRatio="1:1.3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/day_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/input_field_glass"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="6dp">

            <!-- Day Number -->
            <TextView
                android:id="@+id/tv_day_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="@color/gold"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Divider -->
            <View
                android:layout_width="24dp"
                android:layout_height="1dp"
                android:layout_marginVertical="3dp"
                android:background="@color/white"
                android:alpha="0.3" />

            <!-- Suhoor Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/suhoor"
                android:textColor="@color/white"
                android:textSize="9sp"
                android:alpha="0.7" />

            <!-- Suhoor Time -->
            <TextView
                android:id="@+id/tv_suhoor_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="04:30"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- Spacing -->
            <Space
                android:layout_width="1dp"
                android:layout_height="2dp" />

            <!-- Iftar Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/iftar"
                android:textColor="@color/white"
                android:textSize="9sp"
                android:alpha="0.7" />

            <!-- Iftar Time -->
            <TextView
                android:id="@+id/tv_iftar_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="18:30"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
