<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/reader_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background_gradient"
    tools:context=".SurahReaderActivity">

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingBottom="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="52dp"
            android:paddingHorizontal="16dp"
            android:paddingBottom="12dp">

            <!-- Back Button Floating Box -->
            <ImageView
                android:id="@+id/iv_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/input_field_glass"
                android:contentDescription="Back"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:tint="@color/white" />


            <!-- flex spacer left -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Reciter + Mini Player chip (gold button, centred) -->
            <LinearLayout
                android:id="@+id/btn_reciter"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/btn_continue_gold"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp">

                <!-- Prev verse -->
                <ImageView
                    android:id="@+id/iv_prev_verse"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="Previous verse"
                    android:src="@drawable/ic_skip_previous"
                    app:tint="#1A1A1A"
                    android:alpha="0.85" />

                <!-- Play / Pause -->
                <ImageView
                    android:id="@+id/iv_reciter_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginHorizontal="6dp"
                    android:contentDescription="Play/Pause"
                    android:src="@drawable/ic_play"
                    app:tint="#1A1A1A" />

                <!-- Next verse -->
                <ImageView
                    android:id="@+id/iv_next_verse"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="Next verse"
                    android:src="@drawable/ic_skip_next"
                    app:tint="#1A1A1A"
                    android:alpha="0.85" />

                <!-- Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:layout_marginHorizontal="8dp"
                    android:background="#55000000" />

                <!-- Reciter name (tappable to change reciter) -->
                <LinearLayout
                    android:id="@+id/reciter_name_area"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_reciter_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxWidth="70dp"
                        android:maxLines="1"
                        android:text="Alafasy"
                        android:textColor="#1A1A1A"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <!-- Ayah counter -->
                    <TextView
                        android:id="@+id/tv_ayah_counter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ayah 1"
                        android:textColor="#661A1A1A"
                        android:textSize="9sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- flex spacer right -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- invisible 40dp balancer to mirror the back button -->
            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tab_arabic"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/tab_chip_selected_gold"
                android:gravity="center"
                android:text="Arabic"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tab_translation"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:background="@drawable/tab_chip_unselected"
                android:gravity="center"
                android:text="Translation"
                android:textColor="@color/white"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tab_both"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/tab_chip_unselected"
                android:gravity="center"
                android:text="Both"
                android:textColor="@color/white"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/top_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/primary_teal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/surah_header_background"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_surah_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.15"
                        android:text="SURAH 1"
                        android:textColor="@color/gold"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_surah_name_header"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Al-Fatihah"
                        android:textColor="@color/white"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_surah_meaning_header"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="The Opening"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/input_field_glass"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ABOUT"
                    android:textColor="@color/gold"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tv_about"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingMultiplier="1.45"
                    android:text="Loading..."
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="6dp"
                    android:text="VERSE COUNT"
                    android:textColor="@color/gold"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_verse_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Verses: --"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp" />

                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Font size:"
                        android:textColor="@color/gold"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>

                    <SeekBar
                        android:id="@+id/seekbar_font"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:max="26"
                        android:progress="8"
                        android:progressBackgroundTint="@color/white"
                        android:thumbTint="@color/gold"
                        android:progressTint="@color/gold" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/loading_overlay"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="#44000000"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <ProgressBar
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:indeterminateTint="@color/gold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Loading verses..."
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_verses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                tools:listitem="@layout/item_verse" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>