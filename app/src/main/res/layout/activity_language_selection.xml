<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background_gradient"
    android:fitsSystemWindows="true"
    tools:context=".LanguageSelectionActivity">

    <!-- Person with Quran Illustration at Top -->
    <ImageView
        android:id="@+id/iv_illustration"
        android:layout_width="384dp"
        android:layout_height="147dp"
        android:layout_marginTop="16dp"
        android:contentDescription="Muslim reading Quran illustration"
        android:scaleType="fitCenter"
        android:src="@drawable/illustration_muslim_reading"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Glass Card Container (matching login screen) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/glass_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="0dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/glass_card_background"
        android:elevation="8dp"
        android:padding="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_illustration"
        app:layout_constraintVertical_bias="0.0">

        <!-- Globe Icon (will be hidden when list shows) -->
        <FrameLayout
            android:id="@+id/globe_container"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="48dp"
            android:background="@drawable/language_globe_background"
            android:elevation="6dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:contentDescription="Language icon"
                android:src="@drawable/ic_language"
                app:tint="#1E293B" />

        </FrameLayout>

        <!-- Title (will be hidden when list shows) -->
        <TextView
            android:id="@+id/title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/select_your_language"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textAlignment="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/globe_container" />

        <!-- Subtitle (will be hidden when list shows) -->
        <TextView
            android:id="@+id/subtitle_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:textAlignment="center"
            android:text="@string/choose_preferred_language"
            android:textColor="#88FFFFFF"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title_text" />

        <!-- Initial: Centered Container for Select Language Button -->
        <LinearLayout
            android:id="@+id/centered_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Language Selection Area (initially hidden) -->
        <LinearLayout
            android:id="@+id/list_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:alpha="0"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Small Globe + Title Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/language_globe_background"
                    android:elevation="4dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:contentDescription="Language icon"
                        android:src="@drawable/ic_language"
                        app:tint="#1E293B" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/select_language"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/results_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/languages_found"
                        android:textColor="#99FFFFFF"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Compact Search Bar -->
            <LinearLayout
                android:id="@+id/compact_search_container"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/search_input_glass_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="Search"
                    android:src="@drawable/ic_search"
                    app:tint="#99FFFFFF" />

                <EditText
                    android:id="@+id/compact_search_input"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/filter_languages"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="@color/white"
                    android:textColorHint="#66FFFFFF"
                    android:textSize="15sp" />

                <ImageView
                    android:id="@+id/compact_clear_search"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="Clear search"
                    android:src="@drawable/ic_close"
                    android:visibility="gone"
                    app:tint="#99FFFFFF" />

            </LinearLayout>

            <!-- Language List (RecyclerView in ScrollView for reference, but RecyclerView scrolls itself) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/language_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingVertical="8dp"
                android:paddingBottom="16dp" />

        </LinearLayout>

        <!-- Select Language Button (fixed at bottom, same as location button) -->
        <TextView
            android:id="@+id/btn_select_language"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginBottom="0dp"
            android:background="@drawable/btn_gold_gradient"
            android:elevation="8dp"
            android:gravity="center"
            android:text="@string/select_language"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Continue Button (fixed at bottom, initially hidden) -->
        <TextView
            android:id="@+id/btn_continue"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginBottom="0dp"
            android:background="@drawable/btn_gold_gradient"
            android:elevation="8dp"
            android:gravity="center"
            android:text="@string/continue_button"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Mosque Silhouette at Bottom (behind card) -->
    <ImageView
        android:id="@+id/iv_mosque_silhouette"
        android:layout_width="714dp"
        android:layout_height="300dp"
        android:alpha="0.3"
        android:contentDescription="Mosque silhouette"
        android:scaleType="fitXY"
        android:src="@drawable/mosque_skyline_new"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="#FFFFFF" />

</androidx.constraintlayout.widget.ConstraintLayout>
