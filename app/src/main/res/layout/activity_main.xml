<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    tools:context=".MainActivity">

    <!-- Prayer Times Card (Fixed) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/prayer_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_large"
        android:layout_marginTop="120dp"
        android:layout_marginEnd="@dimen/spacing_large"
        android:layout_marginBottom="@dimen/spacing_large"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title Floating Box -->
    <androidx.cardview.widget.CardView
        android:id="@+id/title_container"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_marginStart="@dimen/spacing_large"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/card_background"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/tv_home_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home"
                android:textColor="@color/primary_teal"
                android:textSize="@dimen/text_large"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Notification Icons Floating Box -->
    <androidx.cardview.widget.CardView
        android:id="@+id/notification_container"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_marginEnd="@dimen/spacing_large"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/card_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp">

            <ImageView
                android:id="@+id/iv_notification"
                android:layout_width="@dimen/icon_medium"
                android:layout_height="@dimen/icon_medium"
                android:layout_marginEnd="12dp"
                android:contentDescription="@string/cd_notification_icon"
                android:src="@drawable/bell" />

            <ImageView
                android:id="@+id/iv_more_options"
                android:layout_width="@dimen/icon_medium"
                android:layout_height="@dimen/icon_medium"
                android:contentDescription="@string/cd_more_options"
                android:src="@drawable/ic_more_vert"
                app:tint="@color/primary_teal" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Chat Interface (Scrollable) -->
    <ScrollView
        android:id="@+id/chat_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/spacing_small"
        android:layout_marginTop="@dimen/spacing_small"
        android:layout_marginEnd="@dimen/spacing_small"
        android:layout_marginBottom="4dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/bottom_navigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="400dp"
            android:padding="8dp">

            <!-- Centered Prompt Text -->
            <TextView
                android:id="@+id/tv_chat_prompt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:text="@string/chat_prompt"
                android:textColor="@color/text_dark"
                android:textSize="24sp"
                android:textStyle="normal" />

        </RelativeLayout>
    </ScrollView>

    <!-- Add Attachment Floating Box -->
    <androidx.cardview.widget.CardView
        android:id="@+id/attachment_container"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_marginStart="@dimen/spacing_large"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/card_background"
        app:layout_constraintBottom_toTopOf="@+id/bottom_navigation"
        app:layout_constraintStart_toStartOf="parent">

        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="match_parent"
            android:padding="8dp">

            <ImageView
                android:id="@+id/iv_add_attachment"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:contentDescription="@string/cd_add_icon"
                android:src="@drawable/ic_add"
                app:tint="@color/primary_teal" />
        </FrameLayout>

    </androidx.cardview.widget.CardView>

    <!-- Chat Input Floating Box -->
    <androidx.cardview.widget.CardView
        android:id="@+id/chat_input_container"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="@dimen/spacing_large"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/card_background"
        app:layout_constraintBottom_toTopOf="@+id/bottom_navigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/attachment_container">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_normal"
            android:paddingVertical="4dp">

            <!-- Input Field -->
            <EditText
                android:id="@+id/et_chat_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/chat_input_hint"
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:minHeight="28dp"
                android:paddingHorizontal="@dimen/spacing_small"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/primary_teal"
                android:textSize="@dimen/text_normal" />

            <!-- Microphone Icon -->
            <ImageView
                android:id="@+id/iv_voice_input"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="@dimen/spacing_small"
                android:contentDescription="@string/cd_mic_icon"
                android:src="@drawable/ic_mic"
                app:tint="@color/primary_teal" />

            <!-- Send Button -->
            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/send_button_background" />

                <ImageView
                    android:id="@+id/iv_send_message"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/cd_send_button"
                    android:src="@drawable/send"
                    app:tint="@color/primary_teal" />
            </FrameLayout>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Fixed Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bottom_nav_background_flat"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingVertical="@dimen/spacing_small"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_nav_home"
                android:layout_width="@dimen/icon_medium"
                android:layout_height="@dimen/icon_medium"
                android:contentDescription="@string/cd_home_icon"
                android:src="@drawable/nav_home_selector"
                app:tint="@color/nav_icon_color"/>

            <TextView
                android:id="@+id/tv_nav_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_home"
                android:textColor="@color/nav_text_color"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Qibla -->
        <LinearLayout
            android:id="@+id/nav_qibla"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_nav_qibla"
                android:layout_width="@dimen/icon_medium"
                android:layout_height="@dimen/icon_medium"
                android:contentDescription="@string/cd_compass_icon"
                android:src="@drawable/nav_compass_selector"
                app:tint="@color/nav_icon_color"/>

            <TextView
                android:id="@+id/tv_nav_qibla"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_qibla"
                android:textColor="@color/nav_text_color"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Book -->
        <LinearLayout
            android:id="@+id/nav_book"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_nav_book"
                android:layout_width="@dimen/icon_medium"
                android:layout_height="@dimen/icon_medium"
                android:contentDescription="@string/cd_book_icon"
                android:src="@drawable/nav_book_selector"
                app:tint="@color/nav_icon_color"/>

            <TextView
                android:id="@+id/tv_nav_book"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_book"
                android:textColor="@color/nav_text_color"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>