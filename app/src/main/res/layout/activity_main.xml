<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@drawable/login_background_gradient"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    tools:context=".MainActivity">

    <!-- Prayer Times Card (Fixed) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/prayer_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_large"
        android:layout_marginTop="120dp"
        android:layout_marginEnd="@dimen/spacing_large"
        android:layout_marginBottom="@dimen/spacing_large"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title Floating Box -->
    <LinearLayout
        android:id="@+id/title_container"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/input_field_glass"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_home_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home"
            android:textColor="@color/white"
            android:textSize="@dimen/text_large"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Menu Icon Floating Box -->
    <ImageView
        android:id="@+id/iv_menu"
        android:layout_width="40dp"
        android:layout_height="44dp"
        android:layout_marginStart="@dimen/spacing_large"
        android:layout_marginTop="40dp"
        android:background="@drawable/input_field_glass"
        android:contentDescription="@string/cd_menu_icon"
        android:padding="10dp"
        android:src="@drawable/ic_menu"
        app:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Chat Interface (Scrollable) -->

    <!-- Add Attachment Floating Box -->

    <!-- Add Attachment Floating Box -->
    <ScrollView
        android:id="@+id/chat_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/spacing_small"
        android:layout_marginTop="@dimen/spacing_small"
        android:layout_marginEnd="@dimen/spacing_small"
        android:layout_marginBottom="4dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/bottom_navigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"

        />

    <!-- Add Attachment Floating Box -->
    <ImageView
        android:id="@+id/iv_add_attachment"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="@dimen/spacing_large"
        android:layout_marginBottom="12dp"
        android:background="@drawable/input_field_glass"
        android:contentDescription="@string/cd_add_icon"
        android:padding="10dp"
        android:src="@drawable/ic_add"
        app:tint="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/bottom_navigation"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Chat Input Floating Box -->
    <LinearLayout
        android:id="@+id/chat_input_container"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="@dimen/spacing_large"
        android:layout_marginBottom="12dp"
        android:background="@drawable/input_field_glass"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_normal"
        android:paddingVertical="4dp"
        app:layout_constraintBottom_toTopOf="@+id/bottom_navigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/iv_add_attachment">



            <!-- Input Field -->
            <EditText
                android:id="@+id/et_chat_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/chat_input_hint"
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:minHeight="28dp"
                android:paddingHorizontal="@dimen/spacing_small"
                android:textColor="@color/white"
                android:textColorHint="#77FFFFFF"
                android:textSize="@dimen/text_normal" />

            <!-- Microphone Icon -->
            <ImageView
                android:id="@+id/iv_voice_input"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="@dimen/spacing_small"
                android:contentDescription="@string/cd_mic_icon"
                android:src="@drawable/ic_mic"
                app:tint="@color/white" />

            <!-- Send Button -->

    </LinearLayout>

    <!-- Fixed Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bottom_nav_dark_background"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_nav_home"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/cd_home_icon"
                android:src="@drawable/nav_home_selector"
                app:tint="@color/nav_icon_tint_selector" />

            <TextView
                android:id="@+id/tv_nav_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_home"
                android:textColor="@color/nav_text_color_selector"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Qibla -->
        <LinearLayout
            android:id="@+id/nav_qibla"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_nav_qibla"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/cd_compass_icon"
                android:src="@drawable/nav_compass_selector"
                app:tint="@color/nav_icon_tint_selector" />

            <TextView
                android:id="@+id/tv_nav_qibla"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_qibla"
                android:textColor="@color/nav_text_color_selector"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Center Spacer for FAB -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Quran -->
        <LinearLayout
            android:id="@+id/nav_book"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_nav_book"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/cd_book_icon"
                android:src="@drawable/nav_book_selector"
                app:tint="@color/nav_icon_tint_selector" />

            <TextView
                android:id="@+id/tv_nav_book"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_book"
                android:textColor="@color/nav_text_color_selector"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- More -->
        <LinearLayout
            android:id="@+id/nav_more"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_nav_more"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="More"
                android:src="@drawable/ic_more"
                app:tint="@color/nav_icon_tint_selector" />

            <TextView
                android:id="@+id/tv_nav_more"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="More"
                android:textColor="@color/nav_text_color_selector"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Center Floating Voice Button -->
    <FrameLayout
        android:id="@+id/fab_voice"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/fab_circle_background"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="@+id/bottom_navigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/bottom_navigation">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:contentDescription="Voice Lines"
            android:src="@drawable/voice_lines"
            app:tint="@color/white" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
