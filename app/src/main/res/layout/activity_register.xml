<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/register_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background_gradient"
    android:fitsSystemWindows="true"
    tools:context=".RegisterActivity">

    <!-- Islamic Pattern Background - Very Subtle -->

    <!-- Content Container -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="32dp"
            android:paddingTop="60dp"
            android:paddingBottom="40dp">

            <!-- Back Button -->
            <ImageView
                android:id="@+id/iv_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:background="@drawable/input_field_glass"
                android:contentDescription="@string/cd_back_button"
                android:src="@drawable/ic_back"
                app:tint="@color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Crescent Moon with Stars -->

            <!-- Join Us Text -->
            <TextView
                android:id="@+id/tv_welcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/register_join_us"
                android:textColor="#BBFFFFFF"
                android:textSize="15sp"
                android:letterSpacing="0.15"
                android:textAllCaps="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iv_back" />

            <!-- Create Account Title -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/register_title"
                android:textColor="@color/white"
                android:textSize="38sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_welcome" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/register_subtitle"
                android:textColor="#99FFFFFF"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_title" />

            <!-- Full Name Input Field -->
            <LinearLayout
                android:id="@+id/input_name"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/input_field_glass"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_subtitle">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:alpha="0.8"
                    android:contentDescription="Name icon"
                    android:src="@drawable/ic_person_white" />

                <EditText
                    android:id="@+id/et_full_name"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:background="@null"
                    android:hint="@string/register_name_hint"
                    android:inputType="textPersonName"
                    android:textColor="@color/white"
                    android:textColorHint="#77FFFFFF"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Email Input Field -->
            <LinearLayout
                android:id="@+id/input_email"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/input_field_glass"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/input_name">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:alpha="0.8"
                    android:contentDescription="Email icon"
                    android:src="@drawable/ic_email_white" />

                <EditText
                    android:id="@+id/et_email"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:background="@null"
                    android:hint="@string/login_email_hint"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/white"
                    android:textColorHint="#77FFFFFF"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Password Input Field -->
            <LinearLayout
                android:id="@+id/input_password"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/input_field_glass"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/input_email">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:alpha="0.8"
                    android:contentDescription="Password icon"
                    android:src="@drawable/ic_lock_white" />

                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:background="@null"
                    android:hint="@string/login_password_hint"
                    android:inputType="textPassword"
                    android:textColor="@color/white"
                    android:textColorHint="#77FFFFFF"
                    android:textSize="16sp" />

                <ImageView
                    android:id="@+id/iv_toggle_password"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:alpha="0.6"
                    android:contentDescription="Toggle password visibility"
                    android:padding="2dp"
                    android:src="@drawable/ic_eye_off"
                    app:tint="@color/white" />

            </LinearLayout>

            <!-- Confirm Password Input Field -->
            <LinearLayout
                android:id="@+id/input_confirm_password"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/input_field_glass"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/input_password">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:alpha="0.8"
                    android:contentDescription="Confirm password icon"
                    android:src="@drawable/ic_lock_white" />

                <EditText
                    android:id="@+id/et_confirm_password"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:background="@null"
                    android:hint="@string/register_confirm_password_hint"
                    android:inputType="textPassword"
                    android:textColor="@color/white"
                    android:textColorHint="#77FFFFFF"
                    android:textSize="16sp" />

                <ImageView
                    android:id="@+id/iv_toggle_confirm_password"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:alpha="0.6"
                    android:contentDescription="Toggle confirm password visibility"
                    android:padding="2dp"
                    android:src="@drawable/ic_eye_off"
                    app:tint="@color/white" />

            </LinearLayout>

            <!-- Create Account Button - Gold -->
            <TextView
                android:id="@+id/btn_create_account"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/btn_gold_gradient"
                android:elevation="12dp"
                android:gravity="center"
                android:text="@string/register_button"
                android:textAllCaps="false"
                android:textColor="#1A3D3F"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/input_confirm_password" />

            <!-- Already have account -->
            <LinearLayout
                android:id="@+id/login_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_create_account">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/have_account_text"
                    android:textColor="#99FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_login"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:padding="4dp"
                    android:text="@string/login_link"
                    android:textColor="#FFD700"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Terms -->
            <TextView
                android:id="@+id/tv_terms"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="@string/register_terms"
                android:textColor="#66FFFFFF"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/login_container" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

    <!-- Mosque Silhouette at Bottom -->
    <ImageView
        android:id="@+id/iv_mosque_silhouette"
        android:layout_width="714dp"
        android:layout_height="360dp"
        android:alpha="0.45"
        android:contentDescription="@string/cd_mosque_silhouette"
        android:scaleType="fitXY"
        android:src="@drawable/mosque_skyline_new"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="#FFFFFF" />

</androidx.constraintlayout.widget.ConstraintLayout>
