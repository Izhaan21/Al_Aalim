<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="4dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:id="@+id/verse_card_inner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/input_field_glass"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tv_verse_number"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/verse_number_badge_gold"
                android:gravity="center"
                android:text="1"
                android:textColor="#FFD700"
                android:textSize="12sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <ImageView
                android:id="@+id/iv_verse_share"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="Share verse"
                android:padding="5dp"
                android:src="@drawable/ic_share"
                app:tint="#FFFFFF" />

            <ImageView
                android:id="@+id/iv_verse_play"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginHorizontal="4dp"
                android:contentDescription="Play verse"
                android:padding="5dp"
                android:src="@drawable/ic_play"
                app:tint="#FFFFFF" />

            <ImageView
                android:id="@+id/iv_verse_bookmark"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="Bookmark verse"
                android:padding="5dp"
                android:src="@drawable/ic_bookmark"
                app:tint="#FFFFFF" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_arabic_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:gravity="end"
            android:lineSpacingMultiplier="1.6"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tv_translation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingMultiplier="1.4"
            android:textColor="#FFFFFF"
            android:textSize="13.5sp" />

    </LinearLayout>

</LinearLayout>