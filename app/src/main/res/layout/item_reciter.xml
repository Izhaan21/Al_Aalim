<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="160dp"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#00000000">

    <LinearLayout
        android:id="@+id/reciter_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/input_field_glass"
        android:padding="16dp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">

        <!-- Photo Container -->
        <FrameLayout
            android:id="@+id/photo_layout_container"
            android:layout_width="60dp"
            android:layout_height="60dp">

            <!-- Photo -->
            <androidx.cardview.widget.CardView
                android:layout_width="60dp"
                android:layout_height="60dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/text_medium">

                <ImageView
                    android:id="@+id/reciter_photo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_account"
                    android:contentDescription="Reciter photo" />

            </androidx.cardview.widget.CardView>

            <!-- Selection Indicator -->
            <ImageView
                android:id="@+id/selection_indicator"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="bottom|end"
                android:src="@drawable/ic_check_circle"
                app:tint="@color/gold"
                android:visibility="gone"
                android:contentDescription="Selected" />

        </FrameLayout>

        <!-- English Name (Gold) -->
        <TextView
            android:id="@+id/reciter_name_english"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Mishary Rashid Alafasy"
            android:textColor="@color/gold"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Country (White) -->
        <TextView
            android:id="@+id/reciter_country"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Kuwait"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
