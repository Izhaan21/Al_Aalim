<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/qibla_main"
    android:background="@drawable/login_background_gradient"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    tools:context=".QiblaActivity">

    <!-- Title Floating Box -->
    <LinearLayout
        android:id="@+id/title_container"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginTop="56dp"
        android:background="@drawable/input_field_glass"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_qibla_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/qibla"
            android:textColor="@color/gold"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Back Button -->
    <ImageView
        android:id="@+id/iv_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="56dp"
        android:background="@drawable/input_field_glass"
        android:contentDescription="@string/cd_back_button"
        android:padding="10dp"
        android:src="@drawable/ic_back"
        app:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Map Container -->
    <androidx.cardview.widget.CardView
        android:id="@+id/map_container"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title_container">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Google MapView -->
            <com.google.android.gms.maps.MapView
                android:id="@+id/map_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Kaaba icon overlay -->
            <ImageView
                android:id="@+id/iv_map_kaaba"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="36dp"
                android:contentDescription="@string/cd_kaaba_icon"
                android:src="@drawable/ic_kaaba_new"
                android:visibility="gone" />

            <!-- Expand button -->
            <ImageView
                android:id="@+id/iv_expand_map"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="Expand map"
                android:padding="5dp"
                android:src="@drawable/ic_back"
                android:rotation="135"
                app:tint="#FFFFFF" />

        </FrameLayout>

    </androidx.cardview.widget.CardView>

    <!-- Distance and Angle Info -->
    <LinearLayout
        android:id="@+id/info_section"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/map_container">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingVertical="8dp"
            android:paddingStart="8dp">

            <TextView
                android:id="@+id/tv_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0KM"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Distance from Mecca"
                android:textColor="@color/white"
                android:textSize="11sp" />

        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:layout_gravity="center_vertical"
            android:background="#D1D5DB" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingVertical="8dp"
            android:paddingStart="16dp">

            <TextView
                android:id="@+id/tv_angle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0°"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Device's Angle to Qibla"
                android:textColor="@color/white"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Salah Message - moved below location -->
    <TextView
        android:id="@+id/tv_salah_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/salah_message"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/info_section" />

    <!-- Compass Container -->
    <FrameLayout
        android:id="@+id/compass_container"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginTop="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/info_section">

        <!-- Outer Ring (FIXED - does not rotate) -->
        <ImageView
            android:id="@+id/iv_outer_ring"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_gravity="center"
            android:contentDescription="Outer ring"
            android:src="@drawable/compass_outer_ring" />

        <!-- Inverted Triangle at top (FIXED - does not rotate) -->
        <ImageView
            android:id="@+id/iv_triangle"
            android:layout_width="20dp"
            android:layout_height="14dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="-2dp"
            android:contentDescription="Direction indicator"
            android:src="@drawable/ic_compass_triangle" />

        <!-- Inner Rotating Container -->
        <FrameLayout
            android:id="@+id/rotating_compass"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center">

            <!-- Middle Circle -->
            <ImageView
                android:layout_width="210dp"
                android:layout_height="210dp"
                android:layout_gravity="center"
                android:contentDescription="@string/cd_compass_middle"
                android:src="@drawable/compass_middle_circle" />

            <!-- Inner Circle -->
            <ImageView
                android:layout_width="170dp"
                android:layout_height="170dp"
                android:layout_gravity="center"
                android:contentDescription="@string/cd_compass_inner"
                android:src="@drawable/compass_inner_circle" />

            <!-- Compass Needle (flipped so red points up) -->
            <ImageView
                android:id="@+id/iv_compass_needle"
                android:layout_width="90dp"
                android:layout_height="130dp"
                android:layout_gravity="center"
                android:rotation="180"
                android:contentDescription="@string/cd_compass_needle"
                android:src="@drawable/compass_needle" />



            <!-- Kaaba Icon (moves with compass, at red needle tip, stays upright) -->
            <ImageView
                android:id="@+id/iv_kaaba_indicator"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="8dp"
                android:contentDescription="@string/cd_kaaba_icon"
                android:src="@drawable/ic_kaaba_new" />

        </FrameLayout>

    </FrameLayout>

    <!-- Rotation Guidance Text -->
    <TextView
        android:id="@+id/tv_rotation_guidance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Rotate the phone to find Qibla"
        android:textColor="#B0FFFFFF"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/compass_container" />

    <!-- Location Coordinates -->
    <LinearLayout
        android:id="@+id/location_display"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_rotation_guidance">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="6dp"
            android:contentDescription="@string/cd_location_icon"
            android:src="@drawable/ic_location" />

        <TextView
            android:id="@+id/tv_coordinates"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/default_coordinates"
            android:textColor="@color/white"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Salah Message - between location and instruction -->
    <TextView
        android:id="@+id/tv_salah_message_bottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/salah_message"
        android:textColor="@color/white"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/location_display" />

    <!-- Instruction Text -->
    <TextView
        android:id="@+id/tv_instruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Please lay your phone flat"
        android:textColor="#B0FFFFFF"
        android:textSize="13sp"
        android:textStyle="italic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_salah_message_bottom" />

    <!-- Use My Location Button -->
    <TextView
        android:id="@+id/btn_use_my_location"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/btn_gold_gradient"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        android:gravity="center"
        android:text="Use My Location"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Camel Caravan Container at Bottom -->

</androidx.constraintlayout.widget.ConstraintLayout>
